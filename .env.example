# =============================================
# bogugot-bus-app 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
# cp .env.example .env
# =============================================

# 경기도 버스 OpenAPI
# 발급: https://openapi.gg.go.kr → 회원가입 → API 신청
GYEONGGI_BUS_API_KEY=

# PostgreSQL (docker-compose 기본값 그대로 사용 가능)
DATABASE_URL=postgresql://bogugot:bogugot1234@localhost:5432/bogugot

# Redis (docker-compose 기본값)
REDIS_URL=redis://localhost:6379

# 카카오맵 (지도 기능 구현 때 필요)
# 발급: https://developers.kakao.com → 애플리케이션 추가 → 앱 키
KAKAO_MAP_APP_KEY=

# Firebase Cloud Messaging (알림 기능 구현 때 필요)
# 발급: Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FCM_SERVER_KEY=

# GitHub (PM 에이전트가 Issues 읽을 때 사용)
# 발급: GitHub → Settings → Developer settings → Fine-grained tokens
# 권한: Issues (Read-only), Contents (Read-only)
GITHUB_TOKEN=
GITHUB_REPO=codettk/bogugot-bus-app

# Next.js
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
